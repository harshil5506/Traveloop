PORT=5000
JWT_SECRET=change-this-to-a-long-random-secret

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=traveloop

# Verification
# false keeps the hackathon demo friction-free.
# true blocks login until email or phone OTP is verified.
REQUIRE_VERIFICATION=false
VERIFICATION_CODE_TTL_MINUTES=10

# The current sender prints OTPs to the server console.
# Replace server/services/verificationService.js with SMTP/Twilio/MSG91 calls for production.
NODE_ENV=development
